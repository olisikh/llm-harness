{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://olisikh.github.io/llm-harness/schemas/controller-task.v1.schema.json",
  "title": "Hermes controller task manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task_id", "role", "role_rationale", "mode", "repository", "depends_on", "ownership", "validation_commands", "timeout_seconds", "output_contract", "acceptance_criteria"],
  "properties": {
    "version": {"const": 1},
    "task_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
    "role": {"enum": ["cheap_worker", "coder", "coding_expert", "researcher", "final_reviewer"]},
    "role_rationale": {"type": "string", "minLength": 1},
    "mode": {"enum": ["read_only", "write"]},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "base_commit"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "base_commit": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"}
      }
    },
    "depends_on": {"type": "array", "items": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"}},
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "directory_prefixes"],
      "properties": {
        "files": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "directory_prefixes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "anyOf": [
        {"properties": {"files": {"minItems": 1}}},
        {"properties": {"directory_prefixes": {"minItems": 1}}}
      ]
    },
    "validation_commands": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "timeout_seconds": {"type": "integer", "minimum": 1},
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "required_fields"],
      "properties": {
        "artifact_type": {"enum": ["findings", "candidate"]},
        "required_fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
