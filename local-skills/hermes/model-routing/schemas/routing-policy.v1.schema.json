{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://olisikh.github.io/llm-harness/schemas/routing-policy.v1.schema.json",
  "title": "Hermes semantic model-routing policy",
  "type": "object",
  "required": ["version", "roles", "switching", "limits", "isolation", "review"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": 1},
    "roles": {
      "type": "object",
      "required": ["cheap_worker", "coder", "coding_expert", "researcher", "final_reviewer"],
      "additionalProperties": false,
      "properties": {
        "cheap_worker": {"$ref": "#/$defs/role"},
        "coder": {"$ref": "#/$defs/role"},
        "coding_expert": {"$ref": "#/$defs/role"},
        "researcher": {"$ref": "#/$defs/role"},
        "final_reviewer": {"$ref": "#/$defs/role"}
      }
    },
    "switching": {
      "type": "object",
      "required": ["transport_failures", "configured_api_retries", "same_model_structured_output_repairs", "escalation_after_distinct_model_failures"],
      "additionalProperties": false,
      "properties": {
        "transport_failures": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "configured_api_retries": {"type": "integer", "minimum": 0},
        "same_model_structured_output_repairs": {"type": "integer", "minimum": 0},
        "escalation_after_distinct_model_failures": {"type": "integer", "minimum": 1}
      }
    },
    "limits": {
      "type": "object",
      "required": ["max_parallel_workers", "max_expensive_workers"],
      "additionalProperties": false,
      "properties": {
        "max_parallel_workers": {"type": "integer", "minimum": 1},
        "max_expensive_workers": {"type": "integer", "minimum": 1}
      }
    },
    "isolation": {
      "type": "object",
      "required": ["writer_execution"],
      "additionalProperties": false,
      "properties": {"writer_execution": {"const": "git_worktree"}}
    },
    "review": {
      "type": "object",
      "required": ["role", "required_for_routed_tasks", "max_rejections"],
      "additionalProperties": false,
      "properties": {
        "role": {"const": "final_reviewer"},
        "required_for_routed_tasks": {"const": true},
        "max_rejections": {"type": "integer", "minimum": 1}
      }
    }
  },
  "$defs": {
    "role": {
      "type": "object",
      "required": ["models", "contract", "timeout_seconds"],
      "additionalProperties": false,
      "properties": {
        "models": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/model"}},
        "contract": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {"mode": {"enum": ["read_only", "writer"]}}
        },
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "allowed_tasks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "model": {
      "type": "object",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "reasoning_effort": {"type": "string", "minLength": 1}
      }
    }
  }
}
