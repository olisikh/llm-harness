{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://olisikh.github.io/llm-harness/schemas/controller-result.v1.schema.json",
  "title": "Hermes controller result artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task_id", "state", "code", "summary"],
  "properties": {
    "version": {"const": 1},
    "task_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
    "state": {"enum": ["validation_failure", "scope_violation", "candidate_ready", "base_changed", "review_rejected", "locally_integrated"]},
    "code": {"type": "string"},
    "summary": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "validation_failure"}}},
      "then": {"properties": {"code": {"enum": ["invalid_json", "duplicate_json_key", "input_unavailable", "unsupported_schema_version", "unknown_field", "malformed_task_id", "schema_violation", "duplicate_dependency", "self_dependency", "unrestricted_glob", "path_traversal", "invalid_role_mode", "writer_validation_missing", "invalid_result_code"]}}}
    },
    {"if": {"properties": {"state": {"const": "scope_violation"}}}, "then": {"properties": {"code": {"const": "scope_violation"}}}},
    {"if": {"properties": {"state": {"const": "candidate_ready"}}}, "then": {"properties": {"code": {"const": "candidate_ready"}}}},
    {"if": {"properties": {"state": {"const": "base_changed"}}}, "then": {"properties": {"code": {"const": "base_changed"}}}},
    {"if": {"properties": {"state": {"const": "review_rejected"}}}, "then": {"properties": {"code": {"const": "review_rejected"}}}},
    {"if": {"properties": {"state": {"const": "locally_integrated"}}}, "then": {"properties": {"code": {"const": "locally_integrated"}}}}
  ]
}
