#!/usr/bin/env bash
set -euo pipefail

source_file="${1:-$HOME/.config/sops/secrets.yaml}"
key_file="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"

if [[ ! -s "$source_file" ]]; then
  echo "SOPS source is missing or empty: $source_file" >&2
  exit 1
fi
if [[ ! -r "$key_file" ]]; then
  echo "SOPS age key is unreadable: $key_file" >&2
  exit 1
fi

umask 077
plaintext_file="$(mktemp "${TMPDIR:-/tmp}/sops-verify.XXXXXX")"
trap 'rm -f "$plaintext_file"' EXIT
SOPS_AGE_KEY_FILE="$key_file" sops --decrypt --output-type json "$source_file" > "$plaintext_file"

python3 - "$plaintext_file" <<'PY'
import json
import sys
from pathlib import Path

payload = json.loads(Path(sys.argv[1]).read_text())
if not isinstance(payload, dict) or not payload:
    raise SystemExit("decrypted SOPS payload must be a non-empty object")
leaves = sum(len(value) for value in payload.values() if isinstance(value, dict))
print("sops_source=decryptable")
print("top_level_keys=" + ",".join(sorted(payload)))
print("secret_leaf_count=" + str(leaves))
PY

printf 'source_mode='; stat -f '%Lp' "$source_file"
